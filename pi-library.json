  "themes": {
    "path": ".pi/themes/",
    "available": [
      "catppuccin-mocha",
      "cyberpunk",
      "dracula",
      "everforest",
      "gruvbox",
      "midnight-ocean",
      "nord",
      "ocean-breeze",
      "rose-pine",
      "synthwave",
      "tokyo-night"
    ]
  },
  "presets": {
    "essential": {
      "description": "Core UI + safety \u2014 good starting point for any project",
      "extensions": [
        "tool-counter",
        "theme-cycler",
        "damage-control"
      ],
      "justfileRecipes": {
        "pi": "pi",
        "pi-safe": "pi -e .pi/ext/tool-counter.ts -e .pi/ext/theme-cycler.ts -e .pi/ext/damage-control.ts"
      }
    },
    "focused": {
      "description": "Disciplined workflow \u2014 purpose declaration + task tracking",
      "extensions": [
        "purpose-gate",
        "minimal",
        "theme-cycler"
      ],
      "justfileRecipes": {
        "pi-focused": "pi -e .pi/ext/purpose-gate.ts -e .pi/ext/minimal.ts -e .pi/ext/theme-cycler.ts"
      }
    },
    "team": {
      "description": "Multi-agent orchestration with specialist dispatch",
      "extensions": [
        "agent-team",
        "theme-cycler"
      ],
      "justfileRecipes": {
        "pi-team": "pi -e .pi/ext/agent-team.ts -e .pi/ext/theme-cycler.ts"
      }
    },
    "straw-hats": {
      "description": "One Piece crew \u2014 12 specialist agents with TDD pipeline chains",
      "extensions": [
        "agent-team",
        "agent-chain",
        "tool-counter",
        "theme-cycler",
        "damage-control",
        "scheduler"
      ],
      "justfileRecipes": {
        "pi": "pi -e .pi/ext/tool-counter.ts -e .pi/ext/theme-cycler.ts",
        "crew": "pi -e .pi/ext/agent-team.ts -e .pi/ext/theme-cycler.ts",
        "full-impl": "pi -e .pi/ext/agent-chain.ts -e .pi/ext/theme-cycler.ts",
        "fast-impl": "pi -e .pi/ext/agent-chain.ts -e .pi/ext/theme-cycler.ts",
        "pi-safe": "pi -e .pi/ext/damage-control.ts -e .pi/ext/tool-counter.ts -e .pi/ext/theme-cycler.ts"
      }
    },
    "research": {
      "description": "Research & quant workflows — deep research, quant analysis, recon, security audit via agent chains and team dispatch",
      "extensions": [
        "agent-chain",
        "agent-team",
        "tool-counter",
        "theme-cycler"
      ],
      "justfileRecipes": {
        "pi": "pi -e .pi/extensions/tool-counter.ts -e .pi/extensions/theme-cycler.ts",
        "crew": "pi -e .pi/extensions/agent-team.ts -e .pi/extensions/theme-cycler.ts",
        "chain": "pi -e .pi/extensions/agent-chain.ts -e .pi/extensions/theme-cycler.ts"
      }
    },
    "full": {
      "description": "Everything \u2014 all extensions available via justfile recipes",
      "extensions": [
        "tool-counter",
        "theme-cycler",
        "damage-control",
        "system-select",
        "tilldone",
        "session-replay",
        "cross-agent"
      ],
      "justfileRecipes": {
        "pi": "pi -e .pi/ext/tool-counter.ts -e .pi/ext/theme-cycler.ts",
        "pi-safe": "pi -e .pi/ext/damage-control.ts -e .pi/ext/minimal.ts -e .pi/ext/theme-cycler.ts",
        "pi-focus": "pi -e .pi/ext/purpose-gate.ts -e .pi/ext/minimal.ts -e .pi/ext/theme-cycler.ts",
        "pi-tasks": "pi -e .pi/ext/tilldone.ts -e .pi/ext/theme-cycler.ts",
        "pi-team": "pi -e .pi/ext/agent-team.ts -e .pi/ext/theme-cycler.ts",
        "pi-chain": "pi -e .pi/ext/agent-chain.ts -e .pi/ext/theme-cycler.ts",
        "pi-system": "pi -e .pi/ext/system-select.ts -e .pi/ext/minimal.ts -e .pi/ext/theme-cycler.ts"
      }
    }
  }
}
