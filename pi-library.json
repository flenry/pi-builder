{
  "version": "1.0.0",
  "description": "Pi extension, skill, MCP, and agent template library",
  "extensions": {
    "minimal": {
      "path": "extensions/minimal.ts",
      "description": "Compact footer with model name and 10-block context usage meter",
      "tags": [
        "ui",
        "footer",
        "lightweight"
      ],
      "triggers": [
        "*"
      ],
      "stackable": true,
      "depends": [
        "extensions/themeMap.ts"
      ]
    },
    "pure-focus": {
      "path": "extensions/pure-focus.ts",
      "description": "Strips all footer and status line UI for distraction-free mode",
      "tags": [
        "ui",
        "minimal",
        "focus"
      ],
      "triggers": [
        "*"
      ],
      "stackable": true,
      "depends": [
        "extensions/themeMap.ts"
      ]
    },
    "tool-counter": {
      "path": "extensions/tool-counter.ts",
      "description": "Rich two-line footer: model, context meter, tokens in/out, cost, cwd, git branch, tool call tally",
      "tags": [
        "ui",
        "footer",
        "metrics",
        "cost"
      ],
      "triggers": [
        "*"
      ],
      "stackable": false,
      "depends": [
        "extensions/themeMap.ts"
      ]
    },
    "tool-counter-widget": {
      "path": "extensions/tool-counter-widget.ts",
      "description": "Tool call counts displayed in a below-editor widget",
      "tags": [
        "ui",
        "widget",
        "metrics"
      ],
      "triggers": [
        "*"
      ],
      "stackable": true,
      "depends": [
        "extensions/themeMap.ts"
      ]
    },
    "purpose-gate": {
      "path": "extensions/purpose-gate.ts",
      "description": "Forces intent declaration before working \u2014 keeps the session focused on a single purpose",
      "tags": [
        "workflow",
        "focus",
        "discipline"
      ],
      "triggers": [
        "*"
      ],
      "stackable": false,
      "depends": [
        "extensions/themeMap.ts"
      ]
    },
    "tilldone": {
      "path": "extensions/tilldone.ts",
      "description": "Task-driven discipline \u2014 define tasks before working, tracks progress, nudges completion",
      "tags": [
        "workflow",
        "tasks",
        "discipline",
        "persistence"
      ],
      "triggers": [
        "*"
      ],
      "stackable": false,
      "depends": [
        "extensions/themeMap.ts"
      ]
    },
    "damage-control": {
      "path": "extensions/damage-control.ts",
      "description": "Safety rails \u2014 blocks dangerous bash commands, protects sensitive files, enforces read-only and no-delete paths",
      "tags": [
        "safety",
        "production",
        "devops",
        "guardrails"
      ],
      "triggers": [
        "production",
        "deploy",
        "infrastructure",
        "cdk",
        "aws",
        "docker",
        "kubernetes"
      ],
      "stackable": true,
      "depends": [
        "extensions/themeMap.ts"
      ],
      "requires": {
        "piFiles": [
          ".pi/damage-control-rules.yaml"
        ],
        "npmDeps": [
          "yaml"
        ]
      }
    },
    "system-select": {
      "path": "extensions/system-select.ts",
      "description": "Switch system prompt via /system command \u2014 picks from discovered agent definitions",
      "tags": [
        "agents",
        "workflow",
        "personas"
      ],
      "triggers": [
        "*"
      ],
      "stackable": true,
      "depends": [
        "extensions/themeMap.ts"
      ],
      "requires": {
        "agentDefs": true
      }
    },
    "agent-team": {
      "path": "extensions/agent-team.ts",
      "description": "Multi-agent orchestration \u2014 dispatcher delegates to specialist agents with grid dashboard",
      "tags": [
        "agents",
        "orchestration",
        "multi-agent",
        "complex"
      ],
      "triggers": [
        "monorepo",
        "workspaces",
        "multi-service",
        "microservices",
        "complex"
      ],
      "stackable": false,
      "depends": [
        "extensions/themeMap.ts"
      ],
      "requires": {
        "piFiles": [
          ".pi/agents/teams.yaml"
        ],
        "agentDefs": true
      }
    },
    "agent-chain": {
      "path": "extensions/agent-chain.ts",
      "description": "Sequential pipeline orchestrator \u2014 agents execute in defined order with handoff",
      "tags": [
        "agents",
        "orchestration",
        "pipeline",
        "sequential"
      ],
      "triggers": [
        "monorepo",
        "complex",
        "ci-cd",
        "pipeline"
      ],
      "stackable": false,
      "depends": [
        "extensions/themeMap.ts"
      ],
      "requires": {
        "piFiles": [
          ".pi/agents/teams.yaml",
          ".pi/agents/agent-chain.yaml"
        ],
        "agentDefs": true
      }
    },
    "cross-agent": {
      "path": "extensions/cross-agent.ts",
      "description": "Load commands from .claude/, .gemini/, .codex/ agent directories \u2014 cross-tool compatibility",
      "tags": [
        "interop",
        "commands",
        "multi-tool"
      ],
      "triggers": [
        ".claude",
        ".gemini",
        ".codex"
      ],
      "stackable": true,
      "depends": [
        "extensions/themeMap.ts"
      ]
    },
    "theme-cycler": {
      "path": "extensions/theme-cycler.ts",
      "description": "Cycle themes with Ctrl+X/Ctrl+Q, pick with /theme \u2014 ships with 11 themes",
      "tags": [
        "ui",
        "themes",
        "customization"
      ],
      "triggers": [
        "*"
      ],
      "stackable": true,
      "depends": [
        "extensions/themeMap.ts"
      ],
      "requires": {
        "piFiles": [
          ".pi/themes/"
        ]
      }
    },
    "session-replay": {
      "path": "extensions/session-replay.ts",
      "description": "Scrollable timeline overlay of session history \u2014 review past turns interactively",
      "tags": [
        "ui",
        "history",
        "review",
        "debugging"
      ],
      "triggers": [
        "*"
      ],
      "stackable": true,
      "depends": [
        "extensions/themeMap.ts"
      ]
    },
    "subagent-widget": {
      "path": "extensions/subagent-widget.ts",
      "description": "Spawn sub-agents with /sub <task> \u2014 live streaming progress widget",
      "tags": [
        "agents",
        "sub-agent",
        "widget"
      ],
      "triggers": [
        "*"
      ],
      "stackable": false,
      "depends": [
        "extensions/themeMap.ts"
      ]
    },
    "pi-pi": {
      "path": "extensions/pi-pi.ts",
      "description": "Meta-agent that builds Pi extensions/agents with parallel expert research",
      "tags": [
        "meta",
        "agents",
        "pi-development"
      ],
      "triggers": [
        "pi-development"
      ],
      "stackable": false,
      "depends": [
        "extensions/themeMap.ts"
      ],
      "requires": {
        "piFiles": [
          ".pi/agents/pi-pi/"
        ]
      }
    },
    "scheduler": {
      "path": "extensions/scheduler.ts",
      "description": "In-session recurring and one-shot task scheduling \u2014 fires tasks automatically while you work",
      "tags": [
        "workflow",
        "scheduling",
        "automation",
        "recurring"
      ],
      "triggers": [
        "*"
      ],
      "stackable": true,
      "depends": [
        "extensions/themeMap.ts"
      ]
    },
    "project-context": {
      "path": "extensions/project-context.ts",
      "description": "Injects project context (CLAUDE.md, stack detection, available skills) into every agent system prompt at startup \u2014 agents start smart not cold",
      "tags": [
        "agents",
        "context",
        "workflow",
        "productivity"
      ],
      "triggers": [
        "*"
      ],
      "stackable": true,
      "depends": []
    }
  },
  "skills": {
    "bowser": {
      "path": ".pi/skills/bowser.md",
      "description": "Headless browser automation via Playwright CLI \u2014 UI testing, screenshots, scraping, parallel sessions",
      "tags": [
        "testing",
        "ui",
        "scraping",
        "browser",
        "playwright"
      ],
      "triggers": [
        "react",
        "vue",
        "angular",
        "next",
        "nuxt",
        "svelte",
        "frontend",
        "playwright",
        "cypress",
        "ui-test"
      ],
      "setup": "npx playwright install chromium"
    }
  },
  "mcps": {
    "aws": {
      "description": "AWS service interaction \u2014 CloudFormation, S3, Lambda, DynamoDB, etc.",
      "tags": [
        "cloud",
        "infrastructure",
        "devops",
        "aws"
      ],
      "triggers": [
        "aws-cdk",
        "aws-sdk",
        "@aws-cdk",
        "@aws-sdk",
        "aws-lambda",
        "cloudformation",
        "sam",
        "amplify",
        "boto3",
        "cdk"
      ],
      "config": {
        "command": "npx",
        "args": [
          "-y",
          "@anthropic/aws-mcp"
        ],
        "env": {
          "AWS_PROFILE": "Your AWS profile name",
          "AWS_REGION": "AWS region (e.g. us-east-1)"
        }
      }
    },
    "postgres": {
      "description": "PostgreSQL database interaction \u2014 queries, schema inspection, migrations",
      "tags": [
        "database",
        "sql",
        "postgres"
      ],
      "triggers": [
        "pg",
        "prisma",
        "drizzle",
        "knex",
        "postgresql",
        "typeorm",
        "sequelize"
      ],
      "config": {
        "command": "npx",
        "args": [
          "-y",
          "@anthropic/postgres-mcp"
        ],
        "env": {
          "DATABASE_URL": "PostgreSQL connection string"
        }
      }
    },
    "github": {
      "description": "GitHub API \u2014 issues, PRs, repos, actions, code search",
      "tags": [
        "git",
        "github",
        "ci-cd",
        "collaboration"
      ],
      "triggers": [
        ".github",
        "github-actions",
        "octokit"
      ],
      "config": {
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-github"
        ],
        "env": {
          "GITHUB_PERSONAL_ACCESS_TOKEN": "GitHub PAT with repo scope"
        }
      }
    },
    "filesystem": {
      "description": "Sandboxed filesystem access \u2014 read/write/search with path restrictions",
      "tags": [
        "filesystem",
        "files"
      ],
      "triggers": [
        "*"
      ],
      "config": {
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-filesystem",
          "{projectDir}"
        ]
      }
    },
    "memory": {
      "description": "Persistent knowledge graph \u2014 store and retrieve entities, relations, observations across sessions",
      "tags": [
        "memory",
        "knowledge",
        "persistence"
      ],
      "triggers": [
        "*"
      ],
      "config": {
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-memory"
        ]
      }
    },
    "puppeteer": {
      "description": "Browser automation via Puppeteer \u2014 navigate, screenshot, interact with web pages",
      "tags": [
        "browser",
        "testing",
        "scraping"
      ],
      "triggers": [
        "puppeteer",
        "browser",
        "scraping"
      ],
      "config": {
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-puppeteer"
        ]
      }
    }
  },
